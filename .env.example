# Supabase credentials for the live guest book.
# 1. Create a free project at https://supabase.com
# 2. Go to Project Settings -> API and copy the values below.
# 3. Copy this file to ".env" and paste your values.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
